# =============================================
# Voice Clone 多 Agent 對話系統 — 環境變數範本
# 複製此檔為 .env 並依你的硬體填入
# =============================================

# ── 硬體設定檔（重要：先選這個，其餘欄位才會套用對應預設值）──
# dev  = 開發機 GTX 1660 Ti（6GB VRAM）：STT 用 faster-whisper、TTS 用 Mock
# prod = 正式機 RTX 5090（32GB VRAM）：STT Breeze+faster-whisper 雙引擎、TTS CosyVoice 2
DEVICE_PROFILE=dev

# ── PyTorch 裝置 ──────────────────────────────
# dev：cuda + float16（1660Ti 6GB，避免 float32 OOM）；無 GPU 則 TORCH_DEVICE=cpu
# prod：cuda + bfloat16
TORCH_DEVICE=cuda
TORCH_DTYPE=float16

# ── STT 雙引擎 ────────────────────────────────
# 常用（primary）+ 備援（fallback），primary 逾時或錯誤時自動切換
# 可選值：breeze / faster_whisper / mock
STT_PRIMARY_ENGINE=faster_whisper
STT_FALLBACK_ENGINE=faster_whisper
STT_PRIMARY_TIMEOUT_MS=1500
# 備援也有自己的逾時保護，避免模型首次下載/載入卡住時整個請求無限期 hang 住
STT_FALLBACK_TIMEOUT_MS=8000

# Breeze ASR（MediaTek Research，台灣腔/中英夾雜優化）
# dev 預設關閉（1660Ti 6GB 建議不同時載入）；prod 建議開啟
BREEZE_ASR_ENABLED=false
BREEZE_ASR_MODEL=MediaTek-Research/Breeze-ASR-25

# faster-whisper（通用備援，速度快）
# dev 建議 small/medium；prod 建議 large-v3
WHISPER_MODEL=small
WHISPER_COMPUTE_TYPE=float16

# ── LLM（雲端 API：OpenAI 或 Gemini）───────────
# 只要下面對應 provider 的 API key 有填，系統會自動使用真正的雲端 LLM；
# 留空則自動 fallback 成 MockLLMService（固定測試回覆），不受 TTS_ENGINE
# 是否為 mock 影響——想在 1660Ti 上測試「真的呼叫 Gemini/OpenAI」，
# 只要填這裡的 key 就可以，不需要裝 CosyVoice 2。
LLM_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
LLM_STREAM=true
# 強制一律使用 MockLLMService，即使已經填了 API key（例如想省 API 額度時）
FORCE_MOCK_LLM=false

# ── TTS：CosyVoice 2 ──────────────────────────
# dev：mock（不載入模型，僅驗證管線協定）
# prod：cosyvoice2（本地常駐 WebSocket 服務）
TTS_ENGINE=mock
COSYVOICE_SERVER_HOST=127.0.0.1
COSYVOICE_SERVER_PORT=8100
COSYVOICE_MODEL_PATH=
# 台灣腔微調 LoRA 權重（尚待訓練，見 README「待辦事項」）
COSYVOICE_TAIWAN_LORA_PATH=

# ── 使用者聲音克隆 Profile ────────────────────
VOICE_PROFILES_DIR=voice_profiles
VOICE_SAMPLE_MAX_BYTES=20971520

# ── 多 Agent 設定 ─────────────────────────────
MAX_CONCURRENT_AGENTS=4
# llm_decision（真的呼叫 LLM 判斷該由誰回應，語意理解較準但每次多一次
#               LLM 呼叫、多一點延遲與 API 成本）
# heuristic（規則式，不呼叫 LLM，延遲最低，預設值）
#   heuristic 行為：使用者同時提到多個 agent 名字 → 挑文字中最先出現的
#                   那一個；完全沒提到名字 → 全體依序輪流各自回應一次
AGENT_ROUTING_STRATEGY=heuristic
# llm_decision 策略呼叫 LLM 做路由判斷的逾時保護（毫秒），逾時或呼叫失敗
# 都會自動 fallback 用候選名單第一個 agent，不影響 heuristic 策略
AGENT_ROUTING_LLM_TIMEOUT_MS=5000

# ── 辯論模式設定（agents/debate.py，WS /ws/voice-debate/{session_id}）──
# 兩位 agent 最多輪流講幾輪就自動結束，避免使用者忘記按暫停/結束時，
# 背景一直呼叫 LLM 燒 API 額度、無限講下去。
DEBATE_MAX_TURNS=20
# 節奏控制：換人發言前依該輪預估播放時長補一段等待，讓來回對答的節奏
# 貼近真人聆聽速度（見 agents/debate.py 說明）。單輪等待時間上限（秒）。
DEBATE_MAX_PACING_SECONDS=12

# ── 伺服器 / 傳輸層 ───────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8200
FRONTEND_ORIGIN=http://localhost:5174
# websocket（預設，自架）/ daily / livekit
TRANSPORT=websocket
