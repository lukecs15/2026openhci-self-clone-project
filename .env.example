# =============================================
# Drawing to 3D — 環境變數範本
# 複製此檔為 .env 並填入你的金鑰
# =============================================

# ── Meshy.ai（圖像轉 3D）──────────────────────
# 申請：https://www.meshy.ai/
MESHY_API_KEY=your_meshy_api_key_here

# Meshy.ai 輪詢設定（可選，使用預設值即可）
MESHY_POLL_INTERVAL=3.0
MESHY_POLL_TIMEOUT=300.0

# ── Google Gemini（LLM 對話）─────────────────
# 申請：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 使用的模型（預設 gemini-2.0-flash，可改為 gemini-1.5-pro）
GEMINI_MODEL=gemini-2.0-flash

# ── 伺服器設定 ────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# ── 本地備用模型（TripoSR，可選）─────────────
# TODO: 若啟用本地模型，設定以下參數
# USE_LOCAL_MODEL_FALLBACK=false
# LOCAL_MODEL_WEIGHTS_PATH=/path/to/triposr/weights

# ── 語音系統 ──────────────────────────────────
# ElevenLabs 雲端 TTS 備用（留空則純本地 F5-TTS）
# 申請：https://elevenlabs.io/
ELEVENLABS_API_KEY=

# faster-whisper STT 模型大小（tiny / base / small / medium / large）
# GTX 1650 建議使用 medium（佔約 1.5GB VRAM）
WHISPER_MODEL=medium

# F5-TTS 模型路徑（留空則首次執行時自動下載，約 3GB）
# 下載位置預設為 ~/.cache/huggingface/
F5TTS_MODEL_PATH=

# 語音樣本儲存目錄（相對於 backend/）
VOICE_SAMPLES_DIR=voice_samples

# ── PyTorch 裝置設定 ──────────────────────────
# GTX 1650 建議：cuda + float16（節省 VRAM）
# 若無 GPU：cpu + float32
TORCH_DEVICE=cuda
TORCH_DTYPE=float16

# ── 前端設定（Vite）──────────────────────────
# 若後端不在預設位置，修改此值
# VITE_API_BASE_URL=http://localhost:8000/api
# VITE_WS_BASE_URL=ws://localhost:8000
